// BIGLIGHT Management System — Database schema.
// Giai đoạn hiện tại: SQLite (file trong Docker volume) — đủ cho app nội bộ, không cần server DB riêng.
// Auth: Google OAuth (NextAuth) — bảng User + LoginLog dùng THẬT ngay bây giờ.
// Các bảng nghiệp vụ (Customer, Contract, Revenue…) là nền cho Giai đoạn 2 (UI hiện chạy localStorage).
//
// Lưu ý SQLite: không hỗ trợ enum/Decimal → dùng String (ghi chú giá trị) và Int (tiền yên = số nguyên).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------- Người dùng (Google login) ----------
// role:   "ADMIN" | "MANAGER" | "STAFF" | "VIEWER"
// status: "PENDING"(chờ admin phê duyệt) | "ACTIVE" | "DISABLED"
model User {
  id         String    @id @default(cuid())
  email      String    @unique
  name       String
  image      String?   // avatar Google
  role       String    @default("STAFF")
  status     String    @default("PENDING")
  canView    Boolean   @default(true)  // quyền xem
  canEdit    Boolean   @default(false) // quyền sửa
  canDelete  Boolean   @default(false) // quyền xóa
  department String?
  lastSeenAt  DateTime? // heartbeat → trạng thái online
  lastLoginAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  logins    LoginLog[]
  contracts Contract[]
  okrs      Okr[]
}

// Lịch sử đăng nhập
model LoginLog {
  id        String   @id @default(cuid())
  userId    String
  email     String
  at        DateTime @default(now())
  ip        String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, at])
}

// ---------- Danh mục động (không hard-code) ----------
// type: "EXPENSE" | "REVENUE" | "CUSTOMER_GROUP" | "CONTRACT_TYPE" | ...
model Category {
  id        String   @id @default(cuid())
  type      String
  code      String
  label     String
  labelJa   String?
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([type, code])
  @@index([type])
}

// ---------- Khách hàng ----------
model Customer {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameKana  String?
  groupCode String?  // -> Category(type="CUSTOMER_GROUP")
  contact   String?
  phone     String?
  email     String?
  address   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contracts   Contract[]
  revenues    Revenue[]
  receivables Receivable[]
}

// ---------- Hợp đồng ----------
// status: "DRAFT" | "ACTIVE" | "SUSPENDED" | "CLOSED"
model Contract {
  id         String    @id @default(cuid())
  code       String    @unique
  title      String
  customerId String
  ownerId    String?
  typeCode   String?   // -> Category(type="CONTRACT_TYPE")
  amount     Int       @default(0) // yên
  startDate  DateTime?
  endDate    DateTime?
  status     String    @default("DRAFT")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id])
  owner    User?     @relation(fields: [ownerId], references: [id])
  revenues Revenue[]
}

// ---------- Doanh thu (売上) ----------
model Revenue {
  id           String   @id @default(cuid())
  customerId   String
  contractId   String?
  categoryCode String?  // -> Category(type="REVENUE")
  amount       Int      // yên
  bookedAt     DateTime // ngày ghi nhận doanh thu
  note         String?
  createdAt    DateTime @default(now())

  customer Customer  @relation(fields: [customerId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])

  @@index([bookedAt])
}

// ---------- Chi phí (支出) ----------
model Expense {
  id           String   @id @default(cuid())
  categoryCode String?  // -> Category(type="EXPENSE")
  vendor       String?
  amount       Int      // yên
  spentAt      DateTime
  note         String?
  createdAt    DateTime @default(now())

  @@index([spentAt])
}

// ---------- Công nợ & thu hồi (売掛金・回収) ----------
// status: "OPEN" | "PARTIAL" | "PAID" | "OVERDUE"
model Receivable {
  id         String   @id @default(cuid())
  customerId String
  invoiceNo  String?
  amount     Int      // yên
  paidAmount Int      @default(0)
  dueDate    DateTime
  status     String   @default("OPEN")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  customer    Customer     @relation(fields: [customerId], references: [id])
  collections Collection[]

  @@index([dueDate])
  @@index([status])
}

model Collection {
  id           String   @id @default(cuid())
  receivableId String
  amount       Int      // yên
  collectedAt  DateTime
  method       String?  // bank / cash / ...
  note         String?
  createdAt    DateTime @default(now())

  receivable Receivable @relation(fields: [receivableId], references: [id])
}

// ---------- 予実管理 (Kế hoạch vs Thực tế) ----------
// metric: "REVENUE" | "EXPENSE" | "PROFIT" | ...
model BudgetPlan {
  id        String   @id @default(cuid())
  year      Int
  month     Int      // 1-12
  metric    String
  planned   Int      @default(0) // yên
  actual    Int      @default(0)
  note      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, month, metric])
  @@index([year, month])
}

// ---------- OKR / KPI ----------
// status: "ON_TRACK" | "AT_RISK" | "BEHIND" | "DONE"
model Okr {
  id        String   @id @default(cuid())
  title     String
  ownerId   String?
  quarter   String   // "2026-Q3"
  progress  Int      @default(0) // 0-100
  status    String   @default("ON_TRACK")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner      User?       @relation(fields: [ownerId], references: [id])
  keyResults KeyResult[]
}

model KeyResult {
  id      String  @id @default(cuid())
  okrId   String
  title   String
  target  Float
  current Float   @default(0)
  unit    String?

  okr Okr @relation(fields: [okrId], references: [id], onDelete: Cascade)
}

// ---------- Cài đặt (key-value động) ----------
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
