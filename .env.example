# ===== BIGLIGHT Management — biến môi trường =====
# Copy thành `.env` và điền giá trị thật. KHÔNG commit file .env.

# --- Google OAuth (tạo tại https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URIs cần khai:
#   https://finance.biglight.jp/api/auth/callback/google
#   http://localhost:3000/api/auth/callback/google   (dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth ---
# Tạo secret: openssl rand -base64 32
NEXTAUTH_SECRET=
# Dev: http://localhost:3000 ・ Production được docker-compose đè thành https://finance.biglight.jp
NEXTAUTH_URL=http://localhost:3000

# --- Quy tắc đăng nhập ---
ADMIN_EMAIL=n-tung@biglight.jp
ALLOWED_DOMAIN=biglight.jp

# --- Database (dev dùng file SQLite local; production được docker-compose đè) ---
DATABASE_URL=file:./dev.db
